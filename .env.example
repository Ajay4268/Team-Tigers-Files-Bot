# ── Telegram ──────────────────────────────────────────────────
# Get from https://my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_here

# Get from @BotFather
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MongoDB ───────────────────────────────────────────────────
# Use MongoDB Atlas free tier: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=autofilterbot

# ── Channels ──────────────────────────────────────────────────
# Channel IDs where files are stored (bot must be admin there)
# Separate multiple channels with commas
FILE_CHANNEL=-1001234567890

# Channel ID for bot logs (optional but recommended)
LOG_CHANNEL=-1009876543210

# ── Admins ────────────────────────────────────────────────────
# Your Telegram user ID (get from @userinfobot)
ADMINS=123456789

# ── Settings ─────────────────────────────────────────────────
MAX_RESULTS=10

# ── Force Subscribe ────────────────────────────────────────────
# Comma-separated channel IDs users MUST join to use the bot.
# Bot must be ADMIN in each channel listed here.
# Leave blank to disable force subscribe.
# Example (one channel):  FORCE_SUB_CHANNELS=-1001234567890
# Example (two channels): FORCE_SUB_CHANNELS=-1001234567890,-1009876543210
FORCE_SUB_CHANNELS=

# ── Premium / Payment ──────────────────────────────────────────
# Your UPI ID for receiving payments
UPI_ID=yourname@upi
# Name shown on payment screen
UPI_NAME=Team Tigers

# ── URL Shortener (for non-premium users) ─────────────────────
# Your shortener API key (leave blank to disable shortener)
SHORTENER_API=
# Your shortener domain e.g. mdisklink.com or gplinks.in
SHORTENER_SITE=

# ── Online Streaming ──────────────────────────────────────────
# Base URL of your stream/watch server (optional)
# Leave blank to hide the Watch Online button
STREAM_BASE_URL=

# ── Deploy Info ───────────────────────────────────────────────
DEPLOY_SERVER=Railway
